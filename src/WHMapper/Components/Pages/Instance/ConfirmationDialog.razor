<MudDialog>
    <DialogContent>
        <MudText>@ContentText</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CancelText</MudButton>
        <MudButton Color="@ButtonColor" Variant="Variant.Text" OnClick="Confirm">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>
